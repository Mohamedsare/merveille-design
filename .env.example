# Copier vers .env.local en local. Sur Vercel : Project Settings → Environment Variables.

# --- Supabase (recommandé en production) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL canonique du site (production). Améliore OG / metadata ; sinon Vercel fournit VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# --- Optionnel ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

NEXT_PUBLIC_WHATSAPP_NUMBER=

# DeepSeek / autres APIs serveur (ne jamais préfixer par NEXT_PUBLIC_)
DEEPSEEK_API_KEY=
